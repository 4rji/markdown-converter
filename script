#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
VENV_PATH="${VENV_DIR:-$SCRIPT_DIR/.venv}"
REQUIREMENTS_FILE="$SCRIPT_DIR/requirements.txt"

usage() {
  echo "Usage:"
  echo "  script <input.pdf>           Convert PDF to Markdown"
  echo "  script -i                    Create/reuse .venv + install dependencies"
  echo "  script -r                    Reinstall markitdown"
  exit 1
}

ensure_venv() {
  if [[ ! -x "$VENV_PATH/bin/python" ]]; then
    echo "Virtual environment not found at: $VENV_PATH"
    echo "Run: ./script -i"
    exit 1
  fi
}

if [[ $# -eq 0 ]]; then
  usage
fi

if [[ "$1" == "-i" ]]; then
  if [[ "$(id -u)" -eq 0 ]]; then
    echo "Do not run ./script -i with sudo."
    echo "The project virtual environment must belong to your normal user."
    echo "Run: ./script -i"
    exit 1
  fi

  if [[ ! -x "$VENV_PATH/bin/python" || ! -f "$VENV_PATH/bin/activate" ]]; then
    if [[ -e "$VENV_PATH" ]]; then
      echo "Incomplete virtual environment found at: $VENV_PATH"
      echo "Remove it, then run this command again:"
      echo "  rm -rf \"$VENV_PATH\""
      exit 1
    fi

    PYTHON_VERSION="$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')"
    VENV_PACKAGE="python${PYTHON_VERSION}-venv"

    if command -v apt-get >/dev/null 2>&1; then
      if ! dpkg-query -W -f='${Status}' "$VENV_PACKAGE" 2>/dev/null \
        | grep -q 'install ok installed'; then
        echo "Installing the virtual-environment package required by Python $PYTHON_VERSION..."
        sudo apt-get update
        sudo apt-get install -y python3-venv "$VENV_PACKAGE"
      fi
    fi

    if ! python3 -m venv "$VENV_PATH"; then
      echo
      echo "Could not create the Python $PYTHON_VERSION virtual environment."
      echo "On Ubuntu/Pop!_OS, install it with:"
      echo "  sudo apt-get install python3-venv $VENV_PACKAGE"
      exit 1
    fi
  fi

  source "$VENV_PATH/bin/activate"

  python -m pip install --upgrade pip
  python -m pip install --no-cache-dir -r "$REQUIREMENTS_FILE"

  echo
  echo "Installed in: $VENV_PATH"
  echo "Activate with:"
  echo "source $VENV_PATH/bin/activate"
  echo
  echo "For CUDA Local Whisper, continue with:"
  echo "./install_whisper_local.sh"

  exit 0
fi

if [[ "$1" == "-r" ]]; then
  ensure_venv
  source "$VENV_PATH/bin/activate"

  rm -f "$VENV_PATH/bin/markitdown"

  python -m pip uninstall -y markitdown || true
  python -m pip install --no-cache-dir -r "$REQUIREMENTS_FILE"

  exit 0
fi

input="$1"

if [[ ! -f "$input" ]]; then
  echo "File not found: $input"
  exit 1
fi

ensure_venv
source "$VENV_PATH/bin/activate"

output="${input%.*}.md"

markitdown "$input" > "$output"

echo "Saved: $output"
