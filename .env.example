# OpenAI cloud transcription (optional)
# Create a server-side API key and replace the placeholder below.
# Never commit a real key.
OPENAI_API_KEY=replace_with_your_openai_api_key

# Local Whisper (optional)
# install_whisper_local.sh writes the correct values to .env automatically.
WHISPER_MODEL_PATH=/opt/whisper-models/large-v3-turbo
WHISPER_MODEL_NAME=large-v3-turbo
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
CUDA_VISIBLE_DEVICES=0

# Application tuning (optional)
WHISPER_BEAM_SIZE=5
FFMPEG_TIMEOUT_SECONDS=600
MAX_UPLOAD_SIZE_MB=500

# LD_LIBRARY_PATH is intentionally omitted here because its value depends on
# the installed Python/CUDA packages. install_whisper_local.sh detects and
# writes it to .env.
